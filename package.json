{
  "name": "next-enterprise-starter",
  "version": "1.0.0",
  "description": "基于 Clean Architecture 的企业级 Next.js 全栈模板",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "./scripts/start-dev.sh",
    "dev:next": "next dev --port 3000 --experimental-https --experimental-https-key ./certs/localhost+2-key.pem --experimental-https-cert ./certs/localhost+2.pem",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "db:start": "supabase start",
    "db:reset": "supabase db reset",
    "db:types:local": "supabase gen types typescript --local | node scripts/db-type-transform.js > src/shared/types/database.ts",
    "db:seed": "tsx scripts/seed-auth.ts",
    "db:seed:auth": "tsx scripts/seed-auth.ts",
    "dev:prepare": "pnpm db:reset && pnpm db:types:local && pnpm db:seed",
    "prepare": "husky",
    "secrets-check": "tsx scripts/secrets-check.ts",
    "verify": "pnpm secrets-check && pnpm lint && pnpm type-check && pnpm test && pnpm build"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": "eslint --cache --fix --max-warnings=0 --no-warn-ignored"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.39.0",
    "@tanstack/react-query": "^5.90.3",
    "@tanstack/react-query-devtools": "^5.89.0",
    "@trpc/client": "^11.0.0",
    "@trpc/next": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.1.1",
    "@trpc/tanstack-react-query": "^11.6.0",
    "class-variance-authority": "^0.7.1",
    "client-only": "^0.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "next": "^15.5.9",
    "next-themes": "^0.4.6",
    "openai": "^6.9.1",
    "pino": "^10.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "ulid": "^3.0.2",
    "uuid": "^13.0.0",
    "zod": "^4.1.12",
    "zod-validation-error": "^4.0.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@faker-js/faker": "^10.1.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^22.15.30",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.5.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^5.3.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jest-axe": "^9.0.0",
    "jsdom": "^27.0.0",
    "lint-staged": "^15.2.2",
    "msw": "^2.11.3",
    "pino-pretty": "^13.1.2",
    "postcss": "^8.5.3",
    "prettier": "3.6.2",
    "shadcn": "^3.5.0",
    "tailwindcss": "^4.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "glob": "^11.1.0",
      "tar": "^7.5.2",
      "js-yaml": "^4.1.1",
      "vite": "^7.1.11",
      "body-parser": "^2.2.1"
    }
  }
}
